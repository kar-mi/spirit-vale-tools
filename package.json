{
  "name": "spiritvale-pcap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "electrobun build",
    "build:native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-native.ps1",
    "bundle:native": "bun run scripts/bundle-native.ts",
    "capture:dump": "bun run src/cli/dump.ts",
    "capture:combat": "bun run src/cli/dump.ts --protocols udp --combat-json --combat-log",
    "check": "bun run typecheck && bun test && bun run test:native",
    "dev": "electrobun dev --watch",
    "fetch:windivert": "bun run scripts/fetch-windivert.ts",
    "format:native": "cargo fmt --manifest-path native/capture-helper/Cargo.toml --check",
    "lint:native": "cargo clippy --manifest-path native/capture-helper/Cargo.toml --all-targets -- -D warnings",
    "test": "bun test",
    "test:native": "cargo test --manifest-path native/capture-helper/Cargo.toml",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electrobun": "1.18.1",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
